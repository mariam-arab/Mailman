[gd_scene load_steps=10 format=3 uid="uid://b1mailman1tree"]

; Maple-style tree with a "crumpled paper" canopy. We approximate the
; hand-crumpled tissue look by stacking three sphere blobs at slight offsets
; with three different autumn colors (red, orange, yellow) — the silhouette
; reads as one ragged ball rather than a clean sphere, which is what the
; reference image shows.

[sub_resource type="CapsuleShape3D" id="CapsuleShape3D_trunk"]
radius = 0.32
height = 3.4

[sub_resource type="CylinderMesh" id="CylinderMesh_trunk"]
