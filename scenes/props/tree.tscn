bottom_radius = 0.30
height = 3.4

[sub_resource type="StandardMaterial3D" id="Material_trunk"]
albedo_color = Color(0.36, 0.22, 0.14, 1)
roughness = 1.0

; Three canopy blobs — different sizes give a "crumpled" silhouette.
[sub_resource type="SphereMesh" id="SphereMesh_blob_a"]
