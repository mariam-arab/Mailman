speaker_name = "Ms. Day"
intro_lines = ["Oh — hello! You must be our new mail carrier. I'm Mindy Day, I live in the red house down the way.", "Some of the places along here can be a bit boring, but Ms. Owens at least puts in the effort. Bless her.", "Wish Mr. Gray would too — his house is an absolute eyesore, and it's right next door to mine.", "Anyway, I'll let you get on with it. My kids are playing out front if you need a smile along the way."]
