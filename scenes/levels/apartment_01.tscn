[node name="Martha" parent="." unique_id=1054 instance=ExtResource("6_gossip")]
transform = Transform3D(0, 0, -1, 0, 1, 0, 1, 0, 0, 0.4, 0, 0.6)
speaker_name = "Martha"
intro_lines = ["Oh, a new postie! Name's Martha. Twenty-six years in this complex now — and let me tell you, twenty-six years too long.", "Pipes rattle, the elevator groans, walls thin as paper. Pure neglect, that's what it is.", "And the noise! There's a man on my floor — top floor — bangs on his piano at all hours. Wakes the two floors below us right out of bed.", "Mind you, the landlord lives here too. Tucked away on the first floor, far enough that none of the racket reaches him. Awfully convenient, isn't it?", "Anyhow, I must run — came down to visit my dear friend Anne. She's just over to the left there, all on her own. Welcome to 131 Gomorda Drive, dear!"]
portrait_skin = Color(0.94, 0.78, 0.66, 1)
portrait_body = Color(0.62, 0.28, 0.4, 1)

